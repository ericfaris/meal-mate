# Build stage
FROM node:20-alpine AS builder
WORKDIR /app

ARG EXPO_PUBLIC_API_URL
ENV EXPO_PUBLIC_API_URL=${EXPO_PUBLIC_API_URL}

COPY package*.json ./
RUN npm ci
COPY . .
RUN npx expo export --platform web

# Metro's web bundler does not emit a PWA manifest or service worker. Copy the
# hand-wired PWA files into the export and inject the manifest link + SW
# registration into index.html. APP_VERSION stamps the SW cache name.
ARG APP_VERSION=dev
RUN cp -r public/. dist/ && APP_VERSION=${APP_VERSION} node scripts/inject-pwa.js

# Production stage
FROM nginx:alpine
ARG APP_VERSION=1.0.0
ARG BUILD_NUMBER=1

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf.template /etc/nginx/templates/default.conf.template

LABEL org.opencontainers.image.version="${APP_VERSION}"
LABEL org.opencontainers.image.title="Meal Mate Web"

# nginx listens on ${PORT}, default 80; the lab compose maps host 8600 -> 80.
ENV PORT=80
EXPOSE ${PORT}
CMD ["nginx", "-g", "daemon off;"]
